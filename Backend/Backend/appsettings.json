{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Security": {
    "PasswordSalt" : "__PasswordSalt__"
  },
  "MongoDB": {
    "ConnectionString": "__mongodb_connectionstring__",
    "DatabaseName": "__mongodb_databasename__"
  },
  "Jwt": {
    "Key": "__Secret_Jwt_Key__",
    "Issuer": "__Jwt_Issuer__",
    "Audience": "__Jwt_Audience__"
  },
  "AllowedHosts": "*"
}
